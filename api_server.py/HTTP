# api_server.py
import asyncio
from fastapi import FastAPI, HTTPException
from pydantic import BaseModel

from agent.agent_core import AiCreativeAgent
from agent.schema import AgentRequest
from agent.exceptions import AgentBaseError

# 初始化FastAPI应用
app = FastAPI(title="AI-Creative-Trials Agent Service", version="1.0")
agent = AiCreativeAgent()

# HTTP接收请求模型
class AgentHttpReq(BaseModel):
    user_query: str
    session_id: str | None = None
    model_provider: str = "azure"


@app.post("/api/agent/chat")
async def agent_chat(req: AgentHttpReq):
    """Agent对话接口"""
    try:
        # HTTP入参转换为内部领域模型
        inner_req = AgentRequest(
            user_query=req.user_query,
            session_id=req.session_id,
            model_provider=req.model_provider
        )
        resp = await agent.run(inner_req)
        return {
            "code": 0,
            "msg": "success",
            "data": resp.model_dump()
        }
    except AgentBaseError as e:
        raise HTTPException(status_code=400, detail=f"{type(e).__name__}: {str(e)}")
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Server Error: {str(e)}")

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8000)
